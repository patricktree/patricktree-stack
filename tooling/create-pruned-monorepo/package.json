{
  "name": "@patricktree-stack/create-pruned-monorepo",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*.ts": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    },
    "#src/*": {
      "types": "./dist/types/*",
      "default": "./src/*"
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "turbo run turbo:build",
    "clean": "del-cli --dot=true \"dist\" \"*.tsbuildinfo\"",
    "dev": "turbo run turbo:dev",
    "lint": "turbo run turbo:lint",
    "lint:fix": "turbo run turbo:lint:fix",
    "test:vitest": "vitest run",
    "turbo:build": "tsgo --build ./tsconfig.json",
    "turbo:dev": "tsgo --build ./tsconfig.json --watch",
    "turbo:lint": "oxlint --type-aware --max-warnings 0 .",
    "turbo:lint:fix": "pnpm run turbo:lint --fix",
    "turbo:test": "pnpm run test:vitest"
  },
  "dependencies": {
    "@patricktree-stack/pkg-management": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@patricktree-stack/config-oxlint": "workspace:*",
    "@patricktree-stack/config-typescript": "workspace:*",
    "@patricktree-stack/config-vitest": "workspace:*",
    "@patricktree-stack/test-utils-node": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
