{
  "name": "@patricktree-stack/o11y.node-sdk",
  "private": true,
  "files": [
    "src/**"
  ],
  "type": "module",
  "imports": {
    "#src/*.ts": {
      "types": "./dist/types/*.d.ts",
      "default": "./src/*.ts"
    },
    "#src/*": {
      "types": "./dist/types/*",
      "default": "./src/*"
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "turbo run turbo:build",
    "clean": "del-cli --dot=true \"dist\" \"*.tsbuildinfo\"",
    "lint": "turbo run turbo:lint",
    "lint:fix": "turbo run turbo:lint:fix",
    "turbo:build": "tsc --build ./tsconfig.json",
    "turbo:lint": "oxlint --type-aware --max-warnings 0 .",
    "turbo:lint:fix": "pnpm run turbo:lint --fix"
  },
  "dependencies": {
    "@opentelemetry/api": "catalog:o11y",
    "@opentelemetry/sdk-logs": "catalog:o11y",
    "@opentelemetry/sdk-node": "catalog:o11y",
    "@patricktree/commons-node": "^3.1.1"
  },
  "devDependencies": {
    "@patricktree-stack/config-oxlint": "workspace:*",
    "@patricktree-stack/config-typescript": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  }
}
